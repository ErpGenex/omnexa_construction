{
	"actions": [],
	"allow_rename": 1,
	"autoname": "format:STL-{YYYY}-{#####}",
	"doctype": "DocType",
	"engine": "InnoDB",
	"field_order": [
		"dispute_case",
		"project_contract",
		"settlement_date",
		"settlement_type",
		"settled_amount",
		"settlement_terms",
		"status",
		"company",
		"branch"
	],
	"fields": [
		{"fieldname": "dispute_case", "fieldtype": "Link", "label": "Dispute Case", "options": "Construction Dispute Case", "reqd": 1, "in_list_view": 1},
		{"fieldname": "project_contract", "fieldtype": "Link", "label": "Project Contract", "options": "Project Contract", "fetch_from": "dispute_case.project_contract", "read_only": 1, "in_list_view": 1},
		{"fieldname": "settlement_date", "fieldtype": "Date", "label": "Settlement Date", "default": "Today", "reqd": 1},
		{"fieldname": "settlement_type", "fieldtype": "Select", "label": "Type", "options": "Negotiated\nMediation\nArbitration Award\nDAB Decision", "default": "Negotiated", "reqd": 1},
		{"fieldname": "settled_amount", "fieldtype": "Currency", "label": "Settled Amount", "reqd": 1},
		{"fieldname": "settlement_terms", "fieldtype": "Text", "label": "Terms"},
		{"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nAgreed\nPaid\nClosed", "default": "Draft", "reqd": 1, "in_list_view": 1},
		{"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "Company", "reqd": 1},
		{"fieldname": "branch", "fieldtype": "Link", "label": "Branch", "options": "Branch", "reqd": 1}
	],
	"is_submittable": 1,
	"module": "Omnexa Construction",
	"name": "Construction Settlement",
	"permissions": [
		{"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1},
		{"role": "Construction Commercial Manager", "read": 1, "write": 1, "create": 1, "delete": 0, "submit": 1},
		{"role": "Project Manager", "read": 1, "write": 1, "create": 1, "delete": 0, "submit": 1}
	],
	"track_changes": 1
}

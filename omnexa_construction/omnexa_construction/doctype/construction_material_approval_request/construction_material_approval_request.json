{
	"actions": [],
	"allow_rename": 1,
	"autoname": "format:MAR-{YYYY}-{#####}",
	"doctype": "DocType",
	"engine": "InnoDB",
	"field_order": [
		"project_contract",
		"request_date",
		"status",
		"recipient_title",
		"section_project",
		"project_name",
		"project_number",
		"site_location",
		"contract_number",
		"contractor_name",
		"section_materials",
		"materials",
		"section_attachments",
		"attach_quality_certs",
		"attach_data_sheets",
		"attach_samples",
		"attach_other",
		"section_approval_type",
		"approve_technical",
		"approve_quality",
		"approve_supplier",
		"approve_other",
		"approve_other_specify",
		"consultant_note",
		"section_signatures",
		"prepared_by_name",
		"prepared_by_date",
		"reviewed_by_name",
		"reviewed_by_date",
		"contractor_approved_by",
		"contractor_approved_date",
		"company",
		"branch"
	],
	"fields": [
		{"fieldname": "project_contract", "fieldtype": "Link", "label": "Project Contract", "options": "Project Contract", "reqd": 1, "in_list_view": 1},
		{"fieldname": "request_date", "fieldtype": "Date", "label": "Request Date", "default": "Today", "reqd": 1, "in_list_view": 1},
		{"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nSubmitted\nApproved\nRejected", "default": "Draft", "reqd": 1, "in_list_view": 1},
		{"fieldname": "recipient_title", "fieldtype": "Data", "label": "To (Consultant / Engineer)", "default": "الاستشاري / المهندس"},
		{"fieldname": "section_project", "fieldtype": "Section Break", "label": "Project Data"},
		{"fieldname": "project_name", "fieldtype": "Data", "label": "Project Name", "fetch_from": "project_contract.contract_title", "read_only": 1},
		{"fieldname": "project_number", "fieldtype": "Data", "label": "Project No."},
		{"fieldname": "site_location", "fieldtype": "Data", "label": "Site Location", "fetch_from": "project_contract.site_location"},
		{"fieldname": "contract_number", "fieldtype": "Data", "label": "Contract No.", "fetch_from": "project_contract.name"},
		{"fieldname": "contractor_name", "fieldtype": "Data", "label": "Contractor"},
		{"fieldname": "section_materials", "fieldtype": "Section Break", "label": "Material Details"},
		{"fieldname": "materials", "fieldtype": "Table", "label": "Materials", "options": "Construction Material Approval Line", "reqd": 1},
		{"fieldname": "section_attachments", "fieldtype": "Section Break", "label": "Attachments"},
		{"fieldname": "attach_quality_certs", "fieldtype": "Check", "label": "Quality Certificates"},
		{"fieldname": "attach_data_sheets", "fieldtype": "Check", "label": "Technical Data Sheets"},
		{"fieldname": "attach_samples", "fieldtype": "Check", "label": "Samples"},
		{"fieldname": "attach_other", "fieldtype": "Check", "label": "Other"},
		{"fieldname": "section_approval_type", "fieldtype": "Section Break", "label": "Required Approval"},
		{"fieldname": "approve_technical", "fieldtype": "Check", "label": "Technical Approval", "default": "1"},
		{"fieldname": "approve_quality", "fieldtype": "Check", "label": "Quality Approval", "default": "1"},
		{"fieldname": "approve_supplier", "fieldtype": "Check", "label": "Supplier Approval"},
		{"fieldname": "approve_other", "fieldtype": "Check", "label": "Other"},
		{"fieldname": "approve_other_specify", "fieldtype": "Data", "label": "Other (specify)"},
		{"fieldname": "consultant_note", "fieldtype": "Small Text", "label": "Consultant Note", "default": "لن يتم توريد أو استخدام أي خامات قبل الحصول على الاعتماد الخطي من الاستشاري."},
		{"fieldname": "section_signatures", "fieldtype": "Section Break", "label": "Signatures"},
		{"fieldname": "prepared_by_name", "fieldtype": "Data", "label": "Prepared By"},
		{"fieldname": "prepared_by_date", "fieldtype": "Date", "label": "Prepared Date"},
		{"fieldname": "reviewed_by_name", "fieldtype": "Data", "label": "Reviewed By"},
		{"fieldname": "reviewed_by_date", "fieldtype": "Date", "label": "Reviewed Date"},
		{"fieldname": "contractor_approved_by", "fieldtype": "Data", "label": "Contractor Approved By"},
		{"fieldname": "contractor_approved_date", "fieldtype": "Date", "label": "Contractor Approval Date"},
		{"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "Company", "reqd": 1, "in_list_view": 1},
		{"fieldname": "branch", "fieldtype": "Link", "label": "Branch", "options": "Branch", "reqd": 1}
	],
	"module": "Omnexa Construction",
	"name": "Construction Material Approval Request",
	"permissions": [
		{"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "print": 1},
		{"role": "Project Manager", "read": 1, "write": 1, "create": 1, "delete": 0, "print": 1},
		{"role": "Site Engineer", "read": 1, "write": 1, "create": 1, "delete": 0, "print": 1}
	],
	"track_changes": 1
}

		{"fieldname": "rfi_date", "fieldtype": "Date", "label": "RFI Date", "default": "Today", "reqd": 1, "in_list_view": 1},
		{"fieldname": "subject", "fieldtype": "Data", "label": "Subject", "reqd": 1, "in_list_view": 1},
		{"fieldname": "discipline", "fieldtype": "Select", "label": "Discipline", "options": "\nArchitectural\nStructural\nMEP\nCivil\nGeneral", "in_list_view": 1},

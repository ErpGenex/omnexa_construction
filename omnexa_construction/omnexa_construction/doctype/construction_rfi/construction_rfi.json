		{"role": "Project Manager", "read": 1, "write": 1, "create": 1, "delete": 0, "submit": 1, "cancel": 1},
		{"role": "Site Engineer", "read": 1, "write": 1, "create": 1, "delete": 0, "submit": 1},
		{"role": "Construction Document Controller", "read": 1, "write": 1, "create": 1, "delete": 0, "submit": 1}
	],
	"track_changes": 1

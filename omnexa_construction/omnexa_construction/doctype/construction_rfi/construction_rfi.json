		{"fieldname": "section_question", "fieldtype": "Section Break", "label": "Question"},
		{"fieldname": "question", "fieldtype": "Text Editor", "label": "Question", "reqd": 1},
		{"fieldname": "section_response", "fieldtype": "Section Break", "label": "Response"},
		{"fieldname": "response", "fieldtype": "Text Editor", "label": "Response"},
		{"fieldname": "responded_by", "fieldtype": "Data", "label": "Responded By"},
		{"fieldname": "response_date", "fieldtype": "Date", "label": "Response Date"},
		{"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "Company", "reqd": 1},
		{"fieldname": "branch", "fieldtype": "Link", "label": "Branch", "options": "Branch", "reqd": 1}

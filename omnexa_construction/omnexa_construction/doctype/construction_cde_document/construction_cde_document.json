{
	"actions": [],
	"allow_rename": 1,
	"autoname": "format:CDE-{YYYY}-{#####}",
	"doctype": "DocType",
	"engine": "InnoDB",
	"field_order": ["project_contract", "document_number", "document_title", "revision", "cde_status", "approval_status", "superseded_by", "issued_date", "file_attachment", "notes", "company", "branch"],
	"fields": [
		{"fieldname": "project_contract", "fieldtype": "Link", "label": "Project Contract", "options": "Project Contract", "reqd": 1, "in_list_view": 1},
		{"fieldname": "document_number", "fieldtype": "Data", "label": "Document Number", "reqd": 1, "in_list_view": 1},
		{"fieldname": "document_title", "fieldtype": "Data", "label": "Title", "reqd": 1, "in_list_view": 1},
		{"fieldname": "revision", "fieldtype": "Data", "label": "Revision", "default": "A", "reqd": 1, "in_list_view": 1},
		{"fieldname": "cde_status", "fieldtype": "Select", "label": "CDE Status (ISO 19650)", "options": "WIP\nShared\nPublished\nArchived", "default": "WIP", "reqd": 1},
		{"fieldname": "approval_status", "fieldtype": "Select", "label": "Approval", "options": "Draft\nUnder Review\nApproved\nRejected\nSuperseded", "default": "Draft", "reqd": 1},
		{"fieldname": "superseded_by", "fieldtype": "Link", "label": "Superseded By", "options": "Construction CDE Document", "read_only": 1},
		{"fieldname": "issued_date", "fieldtype": "Date", "label": "Issue Date", "default": "Today"},
		{"fieldname": "file_attachment", "fieldtype": "Attach", "label": "File"},
		{"fieldname": "notes", "fieldtype": "Small Text", "label": "Notes"},
		{"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "Company", "reqd": 1},
		{"fieldname": "branch", "fieldtype": "Link", "label": "Branch", "options": "Branch", "reqd": 1}
	],
	"module": "Omnexa Construction",
	"name": "Construction CDE Document",
	"permissions": [
		{"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
		{"role": "Project Manager", "read": 1, "write": 1, "create": 1, "delete": 0},
		{"role": "Site Engineer", "read": 1, "write": 1, "create": 1, "delete": 0}
	],
	"track_changes": 1
}

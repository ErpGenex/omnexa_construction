	"fields": [
		{"fieldname": "tab_step1", "fieldtype": "Tab Break", "label": "1. Identity"},
		{"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "Company", "reqd": 1, "in_list_view": 1},
		{"fieldname": "branch", "fieldtype": "Link", "label": "Branch", "options": "Branch", "reqd": 1, "in_list_view": 1},
		{"fieldname": "client", "fieldtype": "Link", "label": "Client", "options": "Customer"},
		{"fieldname": "contract_title", "fieldtype": "Data", "label": "Project Title", "in_list_view": 1},
		{"fieldname": "column_break_s1", "fieldtype": "Column Break"},
		{"fieldname": "contract_type", "fieldtype": "Select", "label": "Contract Type", "options": "Turnkey (EPC)\nLump Sum\nUnit Price\nCost Plus", "default": "Turnkey (EPC)", "reqd": 1},
		{"fieldname": "contract_currency", "fieldtype": "Link", "label": "Currency", "options": "Currency", "reqd": 1},
		{"fieldname": "delivery_model", "fieldtype": "Select", "label": "Delivery Model", "options": "Design-Bid-Build\nDesign-Build\nEPC Turnkey", "default": "EPC Turnkey"},
		{"fieldname": "planned_start", "fieldtype": "Date", "label": "Planned Start"},
		{"fieldname": "planned_completion", "fieldtype": "Date", "label": "Planned Completion"},
		{"fieldname": "site_location", "fieldtype": "Small Text", "label": "Site Location"},
		{"fieldname": "wizard_step", "fieldtype": "Int", "label": "Wizard Step", "default": "1"},
		{"fieldname": "tab_financials", "fieldtype": "Tab Break", "label": "Contract Financials"},
		{"fieldname": "retention_percent", "fieldtype": "Percent", "label": "Default Retention %", "default": "5"},
		{"fieldname": "advance_payment_percent", "fieldtype": "Percent", "label": "Advance Payment %"},
		{"fieldname": "advance_payment_amount", "fieldtype": "Currency", "label": "Advance Payment Amount"},
		{"fieldname": "column_break_fin", "fieldtype": "Column Break"},
		{"fieldname": "default_discount_percent", "fieldtype": "Percent", "label": "Default IPC Discount %", "default": "0"},
		{"fieldname": "liquidated_damages_per_day", "fieldtype": "Currency", "label": "Contract LD / day"},
		{"fieldname": "liquidated_damages_cap_percent", "fieldtype": "Percent", "label": "Contract LD cap %"},

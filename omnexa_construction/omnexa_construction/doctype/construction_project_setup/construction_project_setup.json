		{"fieldname": "project_segment", "fieldtype": "Select", "label": "Segment", "options": "Infrastructure\nBuildings\nRoads & Utilities\nIndustrial EPC\nOther"},
		{"fieldname": "building_type", "fieldtype": "Select", "label": "Building / Project Type", "options": "\nairport_terminal\nbridge\ndata_center\ndistrict_cooling\nelectrical_network\nfactory\ngas_network\nhighway\nhospital\nhotel\nlaboratory\nmall\nmetro_station\nmixed_use\noffice_tower\nparking_structure\npower_plant\nrailway\nresidential_building\nresidential_compound\nschool\nsewer_network\nsocial_housing\nsolar_farm\nstadium\nsubstation\ntelecom_fiber\ntunnel\nuniversity\nurban_road\nvilla\nwarehouse\nwastewater_plant\nwater_network"},
		{"fieldname": "boq_template", "fieldtype": "Link", "label": "BOQ Template", "options": "Construction BOQ Template"},
		{"fieldname": "governing_standard", "fieldtype": "Data", "label": "Governing Standard"},
		{"fieldname": "tab_step3", "fieldtype": "Tab Break", "label": "3. Specifications"},
		{"fieldname": "quality_tier", "fieldtype": "Select", "label": "Quality Tier", "options": "Economy\nStandard\nPremium\nLuxury", "default": "Standard"},
		{"fieldname": "plot_area_m2", "fieldtype": "Float", "label": "Plot Area (m²)"},
		{"fieldname": "gross_floor_area_m2", "fieldtype": "Float", "label": "Gross Floor Area (m²)"},
		{"fieldname": "number_of_floors", "fieldtype": "Int", "label": "Floors", "default": "1"},
		{"fieldname": "basement_levels", "fieldtype": "Int", "label": "Basements", "default": "0"},
		{"fieldname": "column_break_s3", "fieldtype": "Column Break"},
		{"fieldname": "unit_count", "fieldtype": "Int", "label": "Units"},
		{"fieldname": "bed_count", "fieldtype": "Int", "label": "Beds"},
		{"fieldname": "key_count", "fieldtype": "Int", "label": "Hotel Keys"},
		{"fieldname": "road_length_m", "fieldtype": "Float", "label": "Road Length (m)"},
		{"fieldname": "road_width_m", "fieldtype": "Float", "label": "Road Width (m)"},
		{"fieldname": "pipe_network_km", "fieldtype": "Float", "label": "Pipe Network (km)"},
		{"fieldname": "tab_phases", "fieldtype": "Tab Break", "label": "4. Phases & Delivery"},
		{"fieldname": "phases", "fieldtype": "Table", "label": "Project Phases", "options": "Construction Project Setup Phase"},
		{"fieldname": "tab_step4", "fieldtype": "Tab Break", "label": "5. BOQ Lines"},
		{"fieldname": "boq_lines", "fieldtype": "Table", "label": "BOQ Lines", "options": "Construction Project Setup BOQ Line"},
		{"fieldname": "tab_boq_details", "fieldtype": "Tab Break", "label": "6. BOQ Detail Pricing"},
		{"fieldname": "boq_details", "fieldtype": "Table", "label": "BOQ Item Details (pricing & LD per detail)", "options": "Construction Project Setup BOQ Detail"},
		{"fieldname": "estimated_contract_value", "fieldtype": "Currency", "label": "Estimated Contract Value", "read_only": 1},
		{"fieldname": "tab_ipc", "fieldtype": "Tab Break", "label": "7. IPC Schedule"},
		{"fieldname": "ipc_plan", "fieldtype": "Table", "label": "IPC / Payment Certificates Plan", "options": "Construction Project Setup IPC Plan"},
		{"fieldname": "tab_step6", "fieldtype": "Tab Break", "label": "8. Assignments"},
		{"fieldname": "assignments", "fieldtype": "Table", "label": "Subcontractors & Suppliers", "options": "Construction Project Setup Assignment"},
		{"fieldname": "tab_contract_terms", "fieldtype": "Tab Break", "label": "Contract Terms"},
		{"fieldname": "contract_terms", "fieldtype": "Table", "label": "Contract Terms & Conditions", "options": "Construction Project Setup Contract Term"},
		{"fieldname": "tab_approval", "fieldtype": "Tab Break", "label": "Approval"},
		{
			"fieldname": "approval_status",
			"fieldtype": "Select",
			"label": "Approval Status",
			"options": "Open\nPending Approval\nApproved\nRejected",
			"default": "Open",
			"in_list_view": 1
		},
		{"fieldname": "setup_revision", "fieldtype": "Int", "label": "Revision", "default": "1", "read_only": 1},
		{"fieldname": "column_break_appr", "fieldtype": "Column Break"},
		{"fieldname": "approved_by", "fieldtype": "Link", "label": "Approved By", "options": "User", "read_only": 1},
		{"fieldname": "approved_on", "fieldtype": "Datetime", "label": "Approved On", "read_only": 1},
		{"fieldname": "approval_notes", "fieldtype": "Small Text", "label": "Approval Notes"},
		{"fieldname": "document_pack_file", "fieldtype": "Attach", "label": "Document Pack (ZIP)", "read_only": 1},
		{"fieldname": "tab_outputs", "fieldtype": "Tab Break", "label": "9. Outputs"},
		{"fieldname": "project_contract", "fieldtype": "Link", "label": "Project Contract", "options": "Project Contract", "read_only": 1},
		{"fieldname": "document_transmittal", "fieldtype": "Link", "label": "Document Transmittal", "options": "Construction Document Transmittal", "read_only": 1},
		{"fieldname": "generated_boq_count", "fieldtype": "Int", "label": "BOQ Lines Created", "read_only": 1},
		{"fieldname": "generated_scw_count", "fieldtype": "Int", "label": "Subcontracts Created", "read_only": 1},
		{"fieldname": "generated_pr_count", "fieldtype": "Int", "label": "Purchase Requests Created", "read_only": 1},
		{"fieldname": "generated_ipc_count", "fieldtype": "Int", "label": "IPC Drafts Created", "read_only": 1},
		{"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nIn Progress\nReady\nCompleted\nFailed", "default": "Draft", "reqd": 1, "in_list_view": 1},
		{"fieldname": "error_log", "fieldtype": "Long Text", "label": "Error Log", "read_only": 1}
	],
	"module": "Omnexa Construction",
	"name": "Construction Project Setup",
	"permissions": [
		{"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "report": 1, "export": 1},
		{"role": "Project Manager", "read": 1, "write": 1, "create": 1, "delete": 0, "report": 1, "export": 1}
	],
	"track_changes": 1
}

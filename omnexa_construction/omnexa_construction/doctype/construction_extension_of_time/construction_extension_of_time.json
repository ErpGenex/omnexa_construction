{
	"actions": [],
	"allow_rename": 1,
	"autoname": "format:EOT-{YYYY}-{#####}",
	"doctype": "DocType",
	"engine": "InnoDB",
	"field_order": [
		"tab_break_overview",
		"project_contract",
		"application_date",
		"notice_reference",
		"cause_category",
		"column_break_omnexa_1",
		"delay_days_claimed",
		"delay_days_approved",
		"tab_break_details",
		"revised_completion_date",
		"related_change_order",
		"column_break_omnexa_2",
		"description",
		"status",
		"company",
		"branch",
		"approval_role"
	],
	"fields": [
		{
			"fieldname": "tab_break_overview",
			"fieldtype": "Tab Break",
			"label": "Overview"
		},
		{
			"fieldname": "tab_break_details",
			"fieldtype": "Tab Break",
			"label": "Details"
		},
		{
			"fieldname": "project_contract",
			"fieldtype": "Link",
			"label": "Project Contract",
			"options": "Project Contract",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "application_date",
			"fieldtype": "Date",
			"label": "Application / notice date",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "notice_reference",
			"fieldtype": "Data",
			"label": "Notice reference",
			"description": "Contractor’s delay notice or claim reference (e.g. FIDIC Sub-Clause 20.1)."
		},
		{
			"fieldname": "cause_category",
			"fieldtype": "Select",
			"label": "Cause category",
			"options": "\nEmployer / Engineer\nForce majeure\nUnforeseeable physical conditions\nLate instructions / variations\nOther",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "delay_days_claimed",
			"fieldtype": "Int",
			"label": "Delay (calendar days claimed)",
			"default": "0"
		},
		{
			"fieldname": "delay_days_approved",
			"fieldtype": "Int",
			"label": "Delay (calendar days approved)",
			"default": "0"
		},
		{
			"fieldname": "revised_completion_date",
			"fieldtype": "Date",
			"label": "Revised completion date (if granted)"
		},
		{
			"fieldname": "related_change_order",
			"fieldtype": "Link",
			"label": "Related change order",
			"options": "Construction Change Order",
			"description": "Optional link if EOT tied to a formal variation."
		},
		{
			"fieldname": "description",
			"fieldtype": "Small Text",
			"label": "Narrative",
			"reqd": 1
		},
		{
			"fieldname": "status",
			"fieldtype": "Select",
			"label": "Status",
			"options": "Draft\nSubmitted\nApproved\nRejected",
			"default": "Draft",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "company",
			"fieldtype": "Link",
			"label": "Company",
			"options": "Company",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "branch",
			"fieldtype": "Link",
			"label": "Branch",
			"options": "Branch",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "approval_role",
			"fieldtype": "Data",
			"label": "Approval Role"
		},
		{
			"fieldname": "column_break_omnexa_1",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "column_break_omnexa_2",
			"fieldtype": "Column Break"
		}
	],
	"module": "Omnexa Construction",
	"name": "Construction Extension of Time",
	"permissions": [
		{
			"role": "System Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1,
			"report": 1,
			"export": 1
		},
		{
			"role": "Project Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0,
			"report": 1,
			"export": 1
		},
		{
			"role": "Site Engineer",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 0,
			"report": 1,
			"export": 0
		}
	],
	"track_changes": 1
}

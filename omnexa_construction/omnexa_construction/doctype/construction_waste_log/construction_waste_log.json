	"module": "Omnexa Construction",
	"name": "Construction Waste Log",
	"permissions": [
		{"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
		{"role": "Construction HSE Officer", "read": 1, "write": 1, "create": 1, "delete": 0},
		{"role": "Site Engineer", "read": 1, "write": 1, "create": 1, "delete": 0}

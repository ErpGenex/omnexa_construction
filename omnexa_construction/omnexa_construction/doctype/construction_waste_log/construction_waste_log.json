		{"fieldname": "waste_type", "fieldtype": "Data", "label": "Waste Type", "reqd": 1, "in_list_view": 1},
		{"fieldname": "quantity", "fieldtype": "Float", "label": "Quantity", "reqd": 1},
		{"fieldname": "uom", "fieldtype": "Link", "label": "UOM", "options": "UOM"},

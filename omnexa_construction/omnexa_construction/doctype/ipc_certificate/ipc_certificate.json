  {"fieldname": "boq_completion_percent", "fieldtype": "Percent", "label": "BOQ Completion % (cumulative)", "default": "0", "reqd": 1, "description": "Cumulative completion % of billable contract value (contract + approved change orders). Period gross = current cumulative value minus last certified IPC cumulative value."},
  {"fieldname": "billable_contract_value", "fieldtype": "Currency", "label": "Billable Contract Value", "read_only": 1, "description": "Project contract value plus approved / implemented change orders."},
  {"fieldname": "prior_cumulative_billed", "fieldtype": "Currency", "label": "Prior Cumulative Billed", "read_only": 1},
  {"fieldname": "cumulative_value_billed", "fieldtype": "Currency", "label": "Cumulative Value (this cert.)", "read_only": 1},
  {"fieldname": "gross_amount", "fieldtype": "Currency", "label": "Period Gross Amount", "read_only": 1},
  {"fieldname": "retention_deduction", "fieldtype": "Currency", "label": "Retention Deduction", "read_only": 1},
  {"fieldname": "advance_recovery", "fieldtype": "Currency", "label": "Advance Recovery", "default": "0"},
  {"fieldname": "net_amount", "fieldtype": "Currency", "label": "Net Amount", "read_only": 1},
  {"fieldname": "section_break_boq", "fieldtype": "Section Break", "label": "BOQ breakdown"},
  {"fieldname": "boq_lines", "fieldtype": "Table", "label": "BOQ Lines", "options": "IPC BOQ Line", "description": "Optional line-level valuation; if filled, period values must sum to Period Gross Amount (within tolerance)."},
  {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nCertified\nPosted\nCancelled", "default": "Draft", "reqd": 1, "in_list_view": 1},
  {"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "Company", "reqd": 1, "in_list_view": 1},
  {"fieldname": "branch", "fieldtype": "Link", "label": "Branch", "options": "Branch", "reqd": 1, "in_list_view": 1}

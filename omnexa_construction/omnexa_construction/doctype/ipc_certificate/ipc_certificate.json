  {"fieldname": "section_break_schedule", "fieldtype": "Section Break", "label": "Schedule Integration"},
  {"fieldname": "pm_wbs_task", "fieldtype": "Link", "label": "PM WBS Task", "options": "PM WBS Task", "description": "Optional schedule anchor for this certificate period (must belong to the same Project Contract)."},

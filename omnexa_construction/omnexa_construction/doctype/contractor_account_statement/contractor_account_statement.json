{
	"actions": [],
	"allow_rename": 1,
	"autoname": "format:CAS-{YYYY}-{#####}",
	"doctype": "DocType",
	"engine": "InnoDB",
	"field_order": [
		"project_contract",
		"statement_date",
		"to_date",
		"status",
		"section_project",
		"project_name",
		"project_number",
		"contractor_name",
		"section_lines",
		"lines",
		"total_executed_works",
		"total_prior_payments",
		"debit_balance_due_contractor",
		"credit_balance_due_from_contractor",
		"notes",
		"disclaimer",
		"section_signatures",
		"prepared_by_name",
		"prepared_by_date",
		"reviewed_by_name",
		"reviewed_by_date",
		"approved_by_name",
		"approved_by_date",
		"company",
		"branch"
	],
	"fields": [
		{"fieldname": "project_contract", "fieldtype": "Link", "label": "Project Contract", "options": "Project Contract", "reqd": 1, "in_list_view": 1},
		{"fieldname": "statement_date", "fieldtype": "Date", "label": "Statement Date", "default": "Today", "reqd": 1, "in_list_view": 1},
		{"fieldname": "to_date", "fieldtype": "Date", "label": "To Date", "reqd": 1},
		{"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nIssued\nAcknowledged", "default": "Draft", "reqd": 1, "in_list_view": 1},
		{"fieldname": "section_project", "fieldtype": "Section Break", "label": "Project Data"},
		{"fieldname": "project_name", "fieldtype": "Data", "label": "Project Name", "fetch_from": "project_contract.contract_title", "read_only": 1},
		{"fieldname": "project_number", "fieldtype": "Data", "label": "Project No."},
		{"fieldname": "contractor_name", "fieldtype": "Data", "label": "Contractor"},
		{"fieldname": "section_lines", "fieldtype": "Section Break", "label": "Statement Lines"},
		{"fieldname": "lines", "fieldtype": "Table", "label": "Lines", "options": "Contractor Account Statement Line"},
		{"fieldname": "total_executed_works", "fieldtype": "Currency", "label": "Total Executed Works", "read_only": 1},
		{"fieldname": "total_prior_payments", "fieldtype": "Currency", "label": "Total Prior Payments", "read_only": 1},
		{"fieldname": "debit_balance_due_contractor", "fieldtype": "Currency", "label": "Debit — Due to Contractor", "read_only": 1},
		{"fieldname": "credit_balance_due_from_contractor", "fieldtype": "Currency", "label": "Credit — Due from Contractor", "read_only": 1},
		{"fieldname": "notes", "fieldtype": "Small Text", "label": "Notes"},
		{"fieldname": "disclaimer", "fieldtype": "Small Text", "label": "Disclaimer", "default": "ملاحظة: هذا الكشف ليس سند صرف."},
		{"fieldname": "section_signatures", "fieldtype": "Section Break", "label": "Signatures"},
		{"fieldname": "prepared_by_name", "fieldtype": "Data", "label": "Prepared By"},
		{"fieldname": "prepared_by_date", "fieldtype": "Date", "label": "Prepared Date"},
		{"fieldname": "reviewed_by_name", "fieldtype": "Data", "label": "Reviewed By"},
		{"fieldname": "reviewed_by_date", "fieldtype": "Date", "label": "Reviewed Date"},
		{"fieldname": "approved_by_name", "fieldtype": "Data", "label": "Approved By"},
		{"fieldname": "approved_by_date", "fieldtype": "Date", "label": "Approved Date"},
		{"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "Company", "reqd": 1, "in_list_view": 1},
		{"fieldname": "branch", "fieldtype": "Link", "label": "Branch", "options": "Branch", "reqd": 1}
	],
	"module": "Omnexa Construction",
	"name": "Contractor Account Statement",
	"permissions": [
		{"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "print": 1},
		{"role": "Project Manager", "read": 1, "write": 1, "create": 1, "delete": 0, "print": 1},
		{"role": "Finance Manager", "read": 1, "write": 1, "create": 1, "delete": 0, "print": 1}
	],
	"track_changes": 1
}

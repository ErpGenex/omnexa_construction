		{"fieldname": "lowest_quote", "fieldtype": "Currency", "label": "Lowest Quote", "read_only": 1},
		{"fieldname": "recommended_supplier", "fieldtype": "Link", "label": "Recommended Supplier", "options": "Supplier", "read_only": 1}
	],
	"links": [
